				</xs:annotation>
			</xs:element>
			<xs:element minOccurs="1" maxOccurs="1" name="token" type="dt:tokenType">
				<xs:annotation>
					<xs:documentation>Token ricevuto tramite l'operazione "create".</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element minOccurs="0" maxOccurs="1" name="contesto" type="dt:contestoType">
				<xs:annotation>
					<xs:documentation>Contesto di validità per il quale il token è stato richiesto.</xs:documentation>
				</xs:annotation>
			</xs:element>			
			<xs:element minOccurs="0" maxOccurs="1" name="applicazione" type="dt:applicazioneType">
				<xs:annotation>
					<xs:documentation>Se il contesto è suddiviso in più applicazioni, indica l'applicazione per la quale il Token è stato richiesto.</xs:documentation>
				</xs:annotation>
			</xs:element>			
          	<xs:element minOccurs="0" name="opzioni" type="dt:opzioni">
				<xs:annotation>
					<xs:documentation>Eventuali campi opzionali. Alcuni contesti potrebbero richiederne la presenza.</xs:documentation>
				</xs:annotation>
			</xs:element>
           	<xs:element minOccurs="0" name="infoAggiuntive" type="dt:infoAggiuntive">
				<xs:annotation>
					<xs:documentation>Elenco di informazioni in input aggiuntive, tipicamente utilizzate in ambiente di test</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="CheckTokenRes">
		<xs:sequence>
			<xs:element minOccurs="1" maxOccurs="1" name="codEsito" type="dt:esitoType">
				<xs:annotation>
					<xs:documentation>Esito della transazione: 0=Esito positivo e restituzione dati, 1=Esito negativo (comunicazioni errori/warning in apposita sezione) e restituzione dati. Per i codici di errore/warning vedere documentazione.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element minOccurs="0" name="errori" type="dt:errori"/>
            <xs:element minOccurs="0" maxOccurs="1" name="infoToken" type="dt:infoToken" />
            <xs:element minOccurs="0" name="info" type="dt:info">
				<xs:annotation>
					<xs:documentation>Struttura per altre comunicazioni in risposta. Tipicamente utilizzati in ambiente di test</xs:documentation>
